# Secret key used to sign JWT tokens. Change this to a random string in production.
JWT_SECRET_KEY=stockflow-super-secret-key-change-this

# Flask app secret key
SECRET_KEY=stockflow-flask-secret-key-change-this

# Database file path (SQLite).
# Left unset on purpose - config.py builds a safe absolute path automatically.
# Uncomment and set this only if you want to point to a different database file.
# DATABASE_URL=sqlite:////absolute/path/to/database.db

# Set to True while developing, False in production
DEBUG=True
